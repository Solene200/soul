# 环境变量配置文件
# 复制此文件为 .env 并填入真实的 API Key

# ModelScope API Key（用于云端大模型）
# 获取方式：访问 https://www.modelscope.cn/my/myaccesstoken 创建 API Token
MODELSCOPE_API_KEY=your_api_key_here
MODELSCOPE_MODEL_NAME=Qwen/Qwen3-Next-80B-A3B-Instruct

# 本地 Ollama 模型（适合轻量 CPU 环境）
OLLAMA_MODEL=qwen3:1.7b

# 数据库配置（可选）
DATABASE_URL=sqlite:///./data/soul.db

# JWT 密钥（可选，默认会自动生成）
SECRET_KEY=your_secret_key_here
